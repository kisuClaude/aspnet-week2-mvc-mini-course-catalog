@model MiniCourseCatalog.Mvc.ViewModels.CourseCreateViewModel
@{ ViewData["Title"] = "Thêm mới khóa học"; }

<div class="page-header">
    <h2 class="page-title">Thêm mới khóa học</h2>
</div>

<div class="form-layout">
    <form class="form-box" asp-controller="Courses" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Title">Tên khóa học</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Department">Khoa/Ban</label>
            <input asp-for="Department" class="form-control" />
            <span asp-validation-for="Department" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Instructor">Giảng viên</label>
            <input asp-for="Instructor" class="form-control" />
            <span asp-validation-for="Instructor" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="TuitionFee">Học phí (VND)</label>
            <input asp-for="TuitionFee" class="form-control" />
            <span asp-validation-for="TuitionFee" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="AvailableSeats">Số chỗ trống ban đầu</label>
            <input asp-for="AvailableSeats" class="form-control" />
            <span asp-validation-for="AvailableSeats" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="WarningThreshold">Ngưỡng báo sắp đầy</label>
            <input asp-for="WarningThreshold" class="form-control" />
            <span asp-validation-for="WarningThreshold" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit">Lưu Khóa Học</button>
        <a class="btn btn-light" asp-controller="Courses" asp-action="Index">Hủy bỏ</a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}