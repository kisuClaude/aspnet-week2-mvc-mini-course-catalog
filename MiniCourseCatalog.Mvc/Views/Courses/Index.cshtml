@model List<CourseListItemViewModel>

@{
    ViewData["Title"] = "Course Catalog";
    Layout = "_Layout";
    var totalCourses = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Course Catalog</h2>
        <p class="page-description">
            Đây là trang danh sách khóa học của hệ thống.
        </p>
    </div>

    <div>
        <a class="btn btn-primary" href="/Courses/Stats">
            Xem thống kê khóa học
        </a>
    </div>
</div>

<div class="info-panel">
    <strong>Tổng số khóa học:</strong> @totalCourses
</div>

@if (Model.Count == 0)
{
    <p>Chưa có khóa học nào trong hệ thống.</p>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead>
            <tr>
                <th>Mã khóa học</th>
                <th>Tên khóa học</th>
                <th>Khoa</th>
                <th>Học phí</th>
                <th>Số chỗ còn lại</th>
                <th>Dự kiến doanh thu</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseCode</td>
                    <td>@item.Title</td>
                    <td>@item.Department</td>
                    <td>@item.FeeText</td>
                    <td>@item.AvailableSeats</td>
                    <td>@item.PotentialRevenueText</td>
                    <td>
                        <span class="@item.EnrollmentStatusClass">
                            @item.EnrollmentStatus
                        </span>
                    </td>
                    <td>
                        <a href="/Courses/Detail/@item.Id">Xem</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<p class="mt-4">
    <a class="btn btn-light" href="/">
        Quay lại trang chủ
    </a>
</p>
