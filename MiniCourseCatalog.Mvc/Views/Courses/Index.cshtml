@model List<MiniCourseCatalog.Mvc.ViewModels.CourseListItemViewModel>
@{
    ViewData["Title"] = "Danh sách khóa học";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Course Catalog</h2>
        <p class="page-description">Danh sách khóa học hiện có. Giao diện dùng Partial View.</p>
    </div>
    <div>
        <a class="btn btn-secondary" asp-controller="Courses" asp-action="Search">Tìm kiếm</a>
        <a class="btn btn-primary" asp-controller="Courses" asp-action="Create">Thêm mới</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        @TempData["SuccessMessage"]
    </div>
}

<div class="info-box">
    <strong>Tổng số khóa học:</strong> @Model.Count
</div>

@if (Model.Count == 0)
{
    <p>Chưa có khóa học nào.</p>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_CourseCard" model="item" />
        }
    </div>
}