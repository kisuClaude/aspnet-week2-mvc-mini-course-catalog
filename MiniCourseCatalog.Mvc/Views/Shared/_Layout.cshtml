<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản lý Khóa học</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-content">
            <div class="brand">
                <a asp-controller="Home" asp-action="Index">MiniCourse.Mvc</a>
            </div>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Courses" asp-action="Index">Khóa học</a>
                <a asp-controller="Courses" asp-action="Filter">Bộ lọc</a>
                <a asp-controller="CourseCategories" asp-action="Index">Danh mục</a>
                <a asp-controller="Enrollments" asp-action="Create">Đăng ký</a>
                <a asp-controller="Enrollments" asp-action="Index">Lịch sử</a>
                <a asp-controller="DataHealth" asp-action="Index">Sức khỏe DB</a>
            </nav>
        </div>
    </header>
    <main class="container main-content">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2026 Hệ thống Quản lý Khóa học - Lab04</span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>