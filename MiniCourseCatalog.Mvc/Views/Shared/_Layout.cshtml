<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Course Catalog</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-content">
            <div class="brand">
                <a asp-controller="Home" asp-action="Index">MiniCourse.Mvc</a>
            </div>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a asp-controller="Courses" asp-action="Index">Khóa học</a>
                <a asp-controller="Courses" asp-action="Stats">Thống kê</a>
                <a asp-controller="Courses" asp-action="Search">Tìm kiếm</a>
                <a asp-controller="Courses" asp-action="Create">Thêm mới</a>
            </nav>
        </div>
    </header>
    <main class="container main-content">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2026 Mini Course Catalog - Lab03</span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>