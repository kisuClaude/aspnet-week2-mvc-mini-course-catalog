@model MiniCourseCatalog.Mvc.ViewModels.EnrollmentFormViewModel
@{
    ViewData["Title"] = "Đăng ký khóa học";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Đăng ký Khóa học trực tuyến</h2>
        <p class="page-description">Form đăng ký học viên vào lớp. Nghiệp vụ lưu nhiều bảng & giảm AvailableSeats sử dụng <strong>EF Core DB Transaction (Commit/Rollback)</strong>.</p>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div style="background-color: #fff5f5; color: #c53030; border: 1px solid #feb2b2; padding: 15px; border-radius: 6px; margin-bottom: 20px; font-weight: bold;">
        @TempData["ErrorMessage"]
    </div>
}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px;">
    <!-- Form Registration -->
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
        <h3 style="margin-top: 0; margin-bottom: 20px; border-bottom: 2px solid #edf2f7; padding-bottom: 10px; color: #2d3748;">Thông tin đăng ký</h3>
        
        <form method="post" asp-controller="Enrollments" asp-action="Create">
            @Html.AntiForgeryToken()

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="FormModel.StudentId" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;"></label>
                <select asp-for="FormModel.StudentId" class="form-control" style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #cbd5e0;">
                    <option value="">-- Chọn học viên --</option>
                    @foreach (var student in Model.Students)
                    {
                        <option value="@student.Id">@student.FullName (@student.Email)</option>
                    }
                </select>
                <span asp-validation-for="FormModel.StudentId" style="color: #e53e3e; font-size: 0.85em; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="FormModel.CourseId" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;"></label>
                <select asp-for="FormModel.CourseId" class="form-control" style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #cbd5e0;">
                    <option value="">-- Chọn khóa học --</option>
                    @foreach (var course in Model.Courses)
                    {
                        var disabled = course.AvailableSeats <= 0 ? "disabled" : null;
                        var seatText = course.AvailableSeats <= 0 ? "HẾT CHỖ" : $"{course.AvailableSeats} chỗ trống";
                        <option value="@course.Id" disabled="@disabled">
                            @course.Title - @course.FeeText (@seatText)
                        </option>
                    }
                </select>
                <span asp-validation-for="FormModel.CourseId" style="color: #e53e3e; font-size: 0.85em; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="FormModel.Remarks" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;"></label>
                <textarea asp-for="FormModel.Remarks" placeholder="Ghi chú thêm về học viên..." rows="3" class="form-control" style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #cbd5e0; resize: vertical;"></textarea>
                <span asp-validation-for="FormModel.Remarks" style="color: #e53e3e; font-size: 0.85em; margin-top: 5px; display: block;"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px; font-size: 1.1em; font-weight: bold;">
                Xác nhận đăng ký học
            </button>
        </form>
    </div>

    <!-- Seat Status Info Panel -->
    <div style="background: #f7fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 25px;">
        <h3 style="margin-top: 0; margin-bottom: 20px; border-bottom: 2px solid #edf2f7; padding-bottom: 10px; color: #2d3748;">Thông tin số ghế trống hiện tại</h3>
        <p style="font-size: 0.9em; color: #718096; margin-bottom: 20px;">Hệ thống sẽ từ chối lưu và rollback transaction nếu số chỗ khả dụng khả dụng đã hết (bằng 0).</p>
        
        <div style="display: flex; flex-direction: column; gap: 15px;">
            @foreach (var course in Model.Courses)
            {
                var isFull = course.AvailableSeats <= 0;
                var colorClass = isFull ? "#fed7d7" : (course.IsLowSeats ? "#feebc8" : "#c6f6d5");
                var borderClass = isFull ? "#feb2b2" : (course.IsLowSeats ? "#fbd38d" : "#9ae6b4");
                var textColor = isFull ? "#9b2c2c" : (course.IsLowSeats ? "#c05621" : "#22543d");

                <div style="background: @colorClass; border: 1px solid @borderClass; color: @textColor; border-radius: 6px; padding: 12px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <strong style="display: block;">@course.Title</strong>
                        <span style="font-size: 0.8em; opacity: 0.85;">Mã KH: @course.CourseCode | SKU: @course.CourseSku</span>
                    </div>
                    <div style="text-align: right;">
                        <span style="font-size: 1.1em; font-weight: bold;">@course.AvailableSeats ghế</span>
                        @if (isFull)
                        {
                            <span style="display: block; font-size: 0.75em; text-transform: uppercase; font-weight: bold; background: #e53e3e; color: white; padding: 2px 4px; border-radius: 3px; margin-top: 3px;">Hết chỗ</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
